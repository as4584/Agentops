{
  "build": {
    "beforeBuildCommand": "cd frontend && npm run build",
    "beforeDevCommand": "cd frontend && npm run dev",
    "devPath": "http://localhost:3000",
    "distDir": "../frontend/out"
  },
  "package": {
    "productName": "Agentop",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "http": {
        "all": true,
        "request": true,
        "scope": ["http://localhost:8000/**"]
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.agentop.app",
      "icon": []
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "Agentop — Local AI Control Center",
        "width": 1400,
        "height": 900
      }
    ]
  }
}
