{
  "name": "agentop-dashboard",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev -p 3007 -H 127.0.0.1",
    "build": "next build",
    "start": "next start -p 3007 -H 127.0.0.1",
    "lint": "next lint",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report ../../reports/playwright/playwright-report",
    "lhci:mobile": "lhci autorun --config=../reports/lhci/lighthouserc.mobile.js",
    "lhci:desktop": "lhci autorun --config=../reports/lhci/lighthouserc.desktop.js",
    "electron:dev": "concurrently -n NEXT,ELECTRON -c cyan,magenta \"npm run dev\" \"wait-on http://localhost:3007 && electron . --no-sandbox --disable-gpu\"",
    "electron:build": "next build && electron-builder"
  },
  "dependencies": {
    "@mantine/code-highlight": "^8.3.15",
    "@mantine/core": "^8.3.15",
    "@mantine/hooks": "^8.3.15",
    "@mantine/notifications": "^8.3.15",
    "@tabler/icons-react": "^3.38.0",
    "next": "^14.2.0",
    "postcss": "^8.5.8",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.53.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "typescript": "^5.4.0",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.agentop.dashboard",
    "productName": "Agentop",
    "directories": {
      "output": "dist"
    },
    "files": [
      ".next/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Agentop"
    }
  }
}
