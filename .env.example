# ── Agentop Environment Template ─────────────────────────────────────────────
# Copy to .env and fill in real values. NEVER commit .env to git.
#
# Secrets should ideally come from Doppler (see doppler.yaml).
# This file exists so a new clone can see every knob the system reads.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM / Router ────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=              # sk-or-v1-... (optional — only needed for cloud LLM routing)
LLM_ROUTER_MODE=hybrid           # hybrid | local | cloud
LLM_MONTHLY_BUDGET=10.0
OLLAMA_MODEL=llama3.2:3b-instruct-q8_0

# ── Operator-Only Deployment Mode ──────────────────────────────────────────
# AGENTOP_DEPLOYMENT_MODE must be "operator_only" (the only supported value).
# This controls startup validation. Changing it to anything else will abort startup.
AGENTOP_DEPLOYMENT_MODE=operator_only

# ── Agentop API Secret ──────────────────────────────────────────────────────
# OPERATOR SECURITY: If BACKEND_HOST is set to a non-loopback address (e.g. 0.0.0.0),
# AGENTOP_API_SECRET MUST be set to a strong random token or startup will be aborted.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# The frontend proxy route injects this server-side — NO NEXT_PUBLIC_ prefix needed.
AGENTOP_API_SECRET=
AGENTOP_API_URL=http://localhost:8000
AGENTOP_CORS_ORIGINS=http://localhost:3007,http://127.0.0.1:3007

# ── Network Exposure (default: loopback only) ────────────────────────────────
# OPERATOR SECURITY: Only change BACKEND_HOST if you need LAN/network access.
# If you do, you MUST set AGENTOP_API_SECRET above or startup will be rejected.
# BACKEND_HOST=127.0.0.1
# AGENTOP_ENABLE_API_DOCS=false  # Never set to true on non-loopback interfaces

# ── Content Pipeline (Jack Craig Strategy) ──────────────────────────────────
CONTENT_NICHE=gaming
UPLOAD_INTERVAL_HOURS=48
VIEW_VELOCITY_THRESHOLD=100
VIEW_VELOCITY_WINDOW_HOURS=12
UPLOAD_HOUR_UTC=14
FAL_KEY=                         # fal.ai key (content video generation)
ELEVENLABS_API_KEY=              # ElevenLabs TTS key

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                    # github_pat_... (for git_ops tool)
GITHUB_USERNAME=

# ── Docker Sandbox (Sprint 8) ──────────────────────────────────────────────
SANDBOX_DOCKER_ENABLED=false
SANDBOX_DOCKER_IMAGE=agentop/sandbox:latest
SANDBOX_DOCKER_NETWORK=none
SANDBOX_DOCKER_MEM_LIMIT=512m
SANDBOX_DOCKER_CPU_LIMIT=1.0
SANDBOX_DOCKER_PIDS_LIMIT=256
SANDBOX_DOCKER_READONLY_ROOTFS=true

# ── TikTok ──────────────────────────────────────────────────────────────────
TIKTOK_REDIRECT_URI=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_REFRESH_TOKEN=

# ── Discord Bot ─────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_IDS=
DISCORD_SECURITY_CHANNEL_ID=
DISCORD_ALERT_POLL_SECONDS=30
DISCORD_NEWS_CHANNEL_NAME=news-intel
DISCORD_NEWS_POLL_SECONDS=600
DISCORD_COMMENT_FARM_WEBHOOK_URL=
DISCORD_COMMENT_FARM_CHANNEL_ID=

# ── Network / Router Ops ────────────────────────────────────────────────────
ROUTER_HOST=
ROUTER_USER=
ROUTER_PASSWORD=
SYSLOG_RECEIVER_IP=              # leave blank to auto-detect WSL2 IP

# ── Facebook / Instagram ────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=
FACEBOOK_APP_TOKEN=
FACEBOOK_USER_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_USERNAME=

# ── Higgsfield AI ───────────────────────────────────────────────────────────
HIGGSFIELD_EMAIL=
HIGGSFIELD_PASSWORD=
HIGGSFIELD_AUTH_METHOD=google_oauth
