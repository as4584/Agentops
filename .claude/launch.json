{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Agentop Backend",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "backend.port_guard", "serve", "backend.server:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Agentop Frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "frontend",
      "port": 3007
    },
    {
      "name": "GLM-OCR Sidecar",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "glmocr.server"],
      "port": 5002
    }
  ]
}
