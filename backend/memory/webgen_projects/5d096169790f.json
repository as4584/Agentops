          "html": "<section id=\"blog\" class=\"bg-gray-100 py-24\">\n  <div class=\"container mx-auto px-6\">\n    <h2 class=\"text-3xl font-bold mb-8 text-center\">Blog</h2>\n    <p class=\"text-lg text-center mb-12\">Stay informed about fitness tips, nutrition advice, and studio updates.</p>\n    <ul class=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">\n      <li aria-label=\"Blog Post 1\" class=\"bg-white shadow rounded-lg overflow-hidden\">\n        <a href=\"#\" class=\"block\">\n          <img src=\"placeholder.jpg\" alt=\"Fitness Tip\" class=\"w-full h-48 object-cover\">\n          <div class=\"p-6\">\n            <h3 class=\"text-xl font-semibold mb-2\">Title of Post 1</h3>\n            <p class=\"text-gray-700\">Short description of the post...</p>\n          </div>\n        </a>\n      </li>\n      <li aria-label=\"Blog Post 2\" class=\"bg-white shadow rounded-lg overflow-hidden\">\n        <a href=\"#\" class=\"block\">\n          <img src=\"placeholder.jpg\" alt=\"Nutrition Advice\" class=\"w-full h-48 object-cover\">\n          <div class=\"p-6\">\n            <h3 class=\"text-xl font-semibold mb-2\">Title of Post 2</h3>\n            <p class=\"text-gray-700\">Short description of the post...</p>\n          </div>\n        </a>\n      </li>\n      <li aria-label=\"Blog Post 3\" class=\"bg-white shadow rounded-lg overflow-hidden\">\n        <a href=\"#\" class=\"block\">\n          <img src=\"placeholder.jpg\" alt=\"Studio Updates\" class=\"w-full h-48 object-cover\">\n          <div class=\"p-6\">\n            <h3 class=\"text-xl font-semibold mb-2\">Title of Post 3</h3>\n            <p class=\"text-gray-700\">Short description of the post...</p>\n          </div>\n        </a>\n      </li>\n    </ul>\n  </div>\n</section>",
