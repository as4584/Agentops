          "html": "<section class=\"bg-white py-10\" id=\"about-us\">\n  <div class=\"container mx-auto px-4\">\n    <h2 class=\"text-3xl font-bold text-center mb-8\">About Us</h2>\n    <p class=\"text-gray-600 text-center mb-8\">Learn more about our mission and team at Apex Fitness Studio.</p>\n    <div class=\"flex flex-wrap justify-center items-center\">\n      <img src=\"/path/to/about-us-image.jpg\" alt=\"Apex Fitness Studio Team\" class=\"w-full md:w-1/2 lg:w-1/3 mb-8 md:mb-0 rounded-lg shadow-lg object-cover\" aria-label=\"Apex Fitness Studio Team\">\n      <div class=\"w-full md:w-1/2 lg:w-1/3 px-4\">\n        <p class=\"text-gray-600 text-center\">At Apex Fitness Studio, we believe in empowering individuals to reach their full potential through challenging and inspiring fitness programs. Our mission is to provide a safe, supportive environment where members can achieve their fitness goals under the guidance of experienced professionals.</p>\n      </div>\n    </div>\n  </div>\n</section>",
          "order": 1
        },
        {
          "id": "035308e9",
          "name": "services",
          "component_type": "service-list",
          "content": {
