#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# Git pre-push hook — CI gate via act
#
# Runs the full .github/workflows/ci.yml workflow locally inside a Docker-based
# GitHub runner (via `act`) before every push.  If any job fails, the push is
# blocked and the error is printed — nothing reaches GitHub.
#
# Requirements
#   • Docker daemon running
#   • act v0.2.x+  (https://github.com/nektos/act)
#     Install: curl -s https://raw.githubusercontent.com/nektos/act/master/install.sh | sudo bash
#   • Runner image pulled at least once:
#     act push -W .github/workflows/ci.yml --pull
#
# Skip (emergency only — not recommended):
#   git push --no-verify
# ──────────────────────────────────────────────────────────────────────────────
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

BOLD='\033[1m'
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
RESET='\033[0m'

echo ""
echo -e "${CYAN}${BOLD}┌─────────────────────────────────────────────────────┐${RESET}"
echo -e "${CYAN}${BOLD}│        pre-push: CI gate  (act / GitHub runner)     │${RESET}"
echo -e "${CYAN}${BOLD}└─────────────────────────────────────────────────────┘${RESET}"
echo ""

# ── Preflight: act must be installed ────────────────────────────────────────
if ! command -v act &>/dev/null; then
    echo -e "${RED}${BOLD}ERROR:${RESET} 'act' is not installed."
    echo ""
    echo "  Install with:"
    echo "    curl -s https://raw.githubusercontent.com/nektos/act/master/install.sh | sudo bash"
    echo ""
    echo "  Then pull the runner image once:"
    echo "    act push -W .github/workflows/ci.yml --pull"
    echo ""
    exit 1
fi

# ── Preflight: Docker must be running ───────────────────────────────────────
if ! docker info &>/dev/null 2>&1; then
    echo -e "${RED}${BOLD}ERROR:${RESET} Docker daemon is not running."
    echo "  Start Docker and retry."
    echo ""
    exit 1
fi

# ── Run the CI gate ──────────────────────────────────────────────────────────
echo -e "  Running: ${BOLD}act push -W .github/workflows/ci.yml${RESET}"
echo -e "  Settings from: ${BOLD}.actrc${RESET}"
echo ""

if act push -W .github/workflows/ci.yml; then
    echo ""
    echo -e "${GREEN}${BOLD}  ✓ CI gate passed — push proceeding.${RESET}"
    echo ""
    exit 0
else
    echo ""
    echo -e "${RED}${BOLD}  ✗ CI gate FAILED — push blocked.${RESET}"
    echo ""
    echo -e "  ${YELLOW}Fix the errors above, then:${RESET}"
    echo "    git push"
    echo ""
    echo -e "  ${YELLOW}Emergency bypass (use sparingly):${RESET}"
    echo "    git push --no-verify"
    echo ""
    exit 1
fi
