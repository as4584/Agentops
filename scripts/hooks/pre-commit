#!/usr/bin/env bash
set -euo pipefail

changed_files=$(git diff --cached --name-only)

if [[ -z "$changed_files" ]]; then
  exit 0
fi

runtime_touched=false
tests_touched=false
py_files=()
ts_files=()

while IFS= read -r file; do
  [[ -z "$file" ]] && continue

  if [[ "$file" == frontend/src/* || "$file" == backend/* ]]; then
    runtime_touched=true
  fi

  if [[ "$file" == frontend/tests/* || "$file" == backend/tests/* ]]; then
    tests_touched=true
  fi

  if [[ "$file" == *.py ]]; then
    py_files+=("$file")
  fi

  if [[ "$file" == *.ts || "$file" == *.tsx ]]; then
    ts_files+=("$file")
  fi
done <<< "$changed_files"

if [[ "$runtime_touched" == true && "$tests_touched" == false ]]; then
  echo "TDD gate failed: runtime code changed without tests in frontend/tests or backend/tests."
  exit 1
fi

if [[ ${#py_files[@]} -gt 0 ]]; then
  python3 -m py_compile "${py_files[@]}"
fi

if [[ ${#ts_files[@]} -gt 0 ]]; then
  (
    cd frontend
    npx tsc --noEmit
  )
fi

echo "pre-commit checks passed"
