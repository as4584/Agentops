#!/usr/bin/env bash
# ──────────────────────────────────────────────────────────────────────────────
# Git pre-commit hook — secret scanner
#
# Scans ONLY staged files for passwords, API keys, IPs, MACs, and other
# credentials before they enter git history. If any violation is found,
# the commit is blocked.
#
# Install:  cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Skip:     git commit --no-verify  (emergency only)
# ──────────────────────────────────────────────────────────────────────────────
set -euo pipefail

echo "┌─────────────────────────────────────────────┐"
echo "│  pre-commit: secret scan (staged files)     │"
echo "└─────────────────────────────────────────────┘"

python3 scripts/scan_secrets.py --staged
EXIT=$?

if [ $EXIT -ne 0 ]; then
    echo ""
    echo "❌ COMMIT BLOCKED — secrets detected in staged files."
    echo "   Fix the violations above, then retry."
    echo "   Emergency bypass: git commit --no-verify"
    echo ""
    exit 1
fi

echo "✓ Secret scan passed."
